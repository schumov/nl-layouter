# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Choose which database backend to use: 'postgres' (default) or 'mssql'
DB_TYPE=postgres

# ── PostgreSQL (Neon or any Postgres) — required when DB_TYPE=postgres ────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── MS SQL Server / Azure SQL — required when DB_TYPE=mssql ──────────────────
# ADO.NET connection string format:
# MSSQL_CONNECTION_STRING=Server=myserver.database.windows.net,1433;Database=nl_layouter;User Id=myuser;Password=mypassword;Encrypt=True;TrustServerCertificate=False;
#
# Local SQL Server / Docker dev (self-signed cert):
# MSSQL_CONNECTION_STRING=Server=localhost,1433;Database=nl_layouter;User Id=sa;Password=YourStrong!Passw0rd;Encrypt=True;TrustServerCertificate=True;
MSSQL_CONNECTION_STRING=
