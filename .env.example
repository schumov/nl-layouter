# .env.example — NL Layouter environment variables
# ============================================================
# Copy this file to apps/server/.env and fill in real values.
# The server reads: apps/server/.env (via dotenv/config in index.ts and drizzle.config.ts)
#
# NEVER commit apps/server/.env — it is excluded by .gitignore
# ============================================================

# ─── Database (REQUIRED) ────────────────────────────────────────────────────
# Get from: Neon.tech Dashboard → Your Project → Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://your-user:your-password@your-host.neon.tech/your-db?sslmode=require

# ─── Server (optional — these have defaults) ────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:3000
NODE_ENV=development
